# Gateway
PORT=8080
AUTH_SERVICE_PORT=8081
AUTH_GRPC_PORT=9091
AUTH_GRPC_TARGET=auth-service:9091

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vocabulary
DB_USER=vocabulary
DB_PASSWORD=vocabulary
DB_SSLMODE=disable

# JWT
JWT_SECRET=change-me
JWT_ACCESS_TTL_MINUTES=15
JWT_PUBLIC_KEY_PATH=

# Local bootstrap admin (development only)
BOOTSTRAP_ADMIN_EMAIL=admin@osonvocabulary.local
BOOTSTRAP_ADMIN_PASSWORD=admin12345

# CORS – restrict to your admin web origin in production, e.g. https://admin.example.com
CORS_ALLOWED_ORIGINS=*

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_WORD_ADDED_EXCHANGE=dictionary.events
RABBITMQ_WORD_ADDED_QUEUE=notification.word-added
RABBITMQ_WORD_ADDED_ROUTING_KEY=word.added

# Firebase Cloud Messaging
FCM_CREDENTIALS_FILE=

