{
  "openapi": "3.0.3",
  "info": {
    "title": "Dictionary Platform API Documentation",
    "description": "API documentation for the Dictionary Platform backend, including Auth, User Management, Vocabulary Management, and System endpoints.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Local Development Server"
    }
  ],
  "paths": {
    "/healthz": {
      "get": {
        "summary": "Health Check",
        "description": "Checks the health status of the API gateway.",
        "responses": {
          "200": {
            "description": "Gateway is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "ok"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1": {
      "get": {
        "summary": "API Version Info",
        "description": "Returns the current version of the API Gateway.",
        "responses": {
          "200": {
            "description": "API Version info retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "service": {
                      "type": "string",
                      "example": "gateway"
                    },
                    "version": {
                      "type": "string",
                      "example": "0.3.0"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/auth/login": {
      "post": {
        "summary": "Admin / User Login",
        "description": "Authenticates a user and returns a JWT access token.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "admin@osonvocabulary.local"
                  },
                  "password": {
                    "type": "string",
                    "format": "password",
                    "example": "admin12345"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully authenticated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "access_token": {
                      "type": "string",
                      "example": "eyJhbGciOiJIUzI1NiIsInR..."
                    },
                    "token_type": {
                      "type": "string",
                      "example": "Bearer"
                    },
                    "expires_in": {
                      "type": "integer",
                      "example": 900
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid credentials or request body"
          }
        }
      }
    },
    "/v1/admins": {
      "post": {
        "summary": "Create Admin User",
        "description": "Creates a new administrator account. Requires Admin credentials.",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "newadmin@osonvocabulary.local"
                  },
                  "password": {
                    "type": "string",
                    "format": "password",
                    "example": "securepassword123"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Admin successfully created"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden (Admin role required)"
          }
        }
      }
    },
    "/v1/vocabulary": {
      "get": {
        "summary": "List Vocabulary",
        "description": "Returns a paginated list of approved vocabulary items.",
        "parameters": [
          {
            "name": "search",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Search keyword for word or translation"
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of vocabulary items retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/VocabularyItem"
                      }
                    },
                    "total": {
                      "type": "integer",
                      "example": 5
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create Vocabulary Item",
        "description": "Creates a new vocabulary item pending approval. Requires User token.",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["word", "translation"],
                "properties": {
                  "word": {
                    "type": "string",
                    "example": "Ubiquitous"
                  },
                  "translation": {
                    "type": "string",
                    "example": "Hamma joyda hozir bo'lgan"
                  },
                  "example": {
                    "type": "string",
                    "example": "Mobile phones are ubiquitous nowadays."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Vocabulary item successfully created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VocabularyItem"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/users/me": {
      "get": {
        "summary": "Get Profile Info",
        "description": "Retrieves information about the currently logged-in user profile.",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "User profile successfully retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "example": "user-uuid"
                    },
                    "email": {
                      "type": "string",
                      "example": "user@example.com"
                    },
                    "role": {
                      "type": "string",
                      "example": "user"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "VocabularyItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "item-uuid"
          },
          "word": {
            "type": "string",
            "example": "Ubiquitous"
          },
          "translation": {
            "type": "string",
            "example": "Hamma joyda hozir bo'lgan"
          },
          "example": {
            "type": "string",
            "example": "Mobile phones are ubiquitous."
          },
          "category": {
            "type": "string",
            "example": "General"
          },
          "status": {
            "type": "string",
            "example": "pending"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
